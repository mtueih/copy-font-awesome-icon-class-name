{
	"manifest_version": 3,
	"name": "__MSG_extensionName__",
	"version": "1.0.1",
	"description": "__MSG_extensionDescription__",
	"default_locale": "en",
	"browser_specific_settings": {
		"gecko": {
			"id": "copy-fa-icon-class-name@mtueih.com",
			"data_collection_permissions": {
				"required": [
					"none"
				],
				"optional": []
			}
		}
	},
	"icons": {
		"16": "icons/icon-16.png",
		"32": "icons/icon-32.png",
		"48": "icons/icon-48.png",
		"96": "icons/icon-96.png",
		"128": "icons/icon-128.png"
	},
	"permissions": [
		"webNavigation",
		"clipboardWrite"
	],
	"host_permissions": [
		"https://fontawesome.com/*"
	],
	"background": {
		"scripts": [
			"background-scripts/url-change-listener.js"
		]
	},
	"content_scripts": [
		{
			"matches": [
				"https://fontawesome.com/*"
			],
			"js": [
				"content-scripts/add-copy-button.js"
			],
			"run_at": "document_start"
		}
	]
}